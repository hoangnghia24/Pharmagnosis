<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".views.activities.SplashActivity">

    <LinearLayout
        android:id="@+id/layout_logo_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_logo_splash"
            android:layout_width="150dp"
            android:layout_height="150dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="75dp"
            app:cardElevation="16dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/iv_logo_splash"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_marginStart="-75dp"
                android:layout_marginTop="-75dp"
                android:padding="24dp"
                android:scaleType="centerInside"
                android:src="@drawable/img_logo" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_app_name_splash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:letterSpacing="0.05"
            android:text="Pharmagnosis"
            android:textColor="#1976D2"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_slogan_splash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hệ thống quản lý dược phẩm"
            android:textColor="#64748B"
            android:textSize="16sp"
            android:letterSpacing="0.02"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pb_splash"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginBottom="60dp"
        android:indeterminateTint="#1976D2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>