<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="16dp"
    android:layout_marginBottom="-24dp"
    android:layout_marginHorizontal="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:background="@android:color/white">

        <View
            android:id="@+id/dragHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#DDDDDD"
            android:backgroundTint="#CCCCCC"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="-16dp" />

        <ImageView
            android:id="@+id/ivPharmacyIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_pharmacy"
            app:layout_constraintTop_toBottomOf="@id/dragHandle"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/tvPharmacyName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tên Nhà Thuốc"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            app:layout_constraintTop_toTopOf="@id/ivPharmacyIcon"
            app:layout_constraintStart_toEndOf="@id/ivPharmacyIcon"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="16dp"/>

        <TextView
            android:id="@+id/tvPharmacyAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Đang tải địa chỉ..."
            android:textSize="14sp"
            android:textColor="#555555"
            app:layout_constraintTop_toBottomOf="@id/tvPharmacyName"
            app:layout_constraintStart_toStartOf="@id/tvPharmacyName"
            app:layout_constraintEnd_toEndOf="@id/tvPharmacyName"
            android:layout_marginTop="4dp"/>

        <View
            android:id="@+id/separator"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            app:layout_constraintTop_toBottomOf="@id/ivPharmacyIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"/>

        <Button
            android:id="@+id/btnDirections"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="CHỈ ĐƯỜNG"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#007BFF"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/separator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>