<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Ảnh thuốc ở trên cùng -->
    <ImageView
        android:id="@+id/imgMedicine"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#F8F9FA"
        android:contentDescription="Hình ảnh thuốc"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Thanh công cụ đè lên ảnh -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white"
            android:contentDescription="Quay lại"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#212121" />

        <ImageView
            android:id="@+id/imgBookmark"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white"
            android:contentDescription="Lưu thuốc"
            android:padding="8dp"
            android:src="@drawable/ic_bookmark_outline"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#212121" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomAction"
        app:layout_constraintTop_toBottomOf="@id/imgMedicine">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/txtMedicineName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Paracetamol 500mg"
                android:textColor="#212121"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Không kê đơn (OTC)"
                    android:textColor="#1976D2"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Viên nén"
                    android:textColor="#757575"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Giảm đau - Hạ sốt"
                    android:textColor="#757575"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_warning_box"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cảnh báo tương tác thuốc"
                    android:textColor="#D32F2F"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Không dùng chung với rượu bia để tránh tổn thương gan. Thận trọng với Isoniazid."
                    android:textColor="#D32F2F"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayoutMedicine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:tabIndicatorColor="#1976D2"
                app:tabMode="scrollable"
                app:tabSelectedTextColor="#1976D2"
                app:tabTextAppearance="@style/TextAppearance.AppCompat.Small"
                app:tabTextColor="#757575">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chỉ định" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Liều dùng" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chống chỉ định" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T.dụng phụ" />

            </com.google.android.material.tabs.TabLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Công dụng chính"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMedicineDetailContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="6dp"
                android:text="• Giảm các cơn đau nhẹ đến vừa như: đau đầu, đau răng, đau bụng kinh.\n\n• Hạ sốt do cảm lạnh, cảm cúm, hoặc sau khi tiêm chủng.\n\n• Giảm đau nhức cơ xương khớp nhẹ."
                android:textColor="#424242"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddPrescription"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="+ Thêm vào toa"
            android:textColor="#1976D2"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="#1976D2"
            app:strokeWidth="1.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSetReminder"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Đặt nhắc nhở"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#1976D2"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_alarm_clock"
            app:iconGravity="textStart"
            app:iconTint="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>