<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgMedicine"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="#F5F5F5"
            android:scaleType="centerCrop"
            android:contentDescription="Ảnh thuốc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/txtMedicineName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Paracetamol 500mg"
            android:textColor="#212121"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgMedicine"
            app:layout_constraintEnd_toStartOf="@id/imgBookmark"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imgBookmark"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_bookmark_outline" app:tint="#BDBDBD"
            android:contentDescription="Lưu thuốc"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutTags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="@id/txtMedicineName"
            app:layout_constraintTop_toBottomOf="@id/txtMedicineName">

            <TextView
                android:id="@+id/txtTag1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Viên nén"
                android:textColor="#757575"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/txtTag2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_chip_outline"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Giảm đau - Hạ sốt"
                android:textColor="#757575"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txttradeName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="NSX: Dược Hậu Giang (DHG)"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/txtMedicineName"
            app:layout_constraintTop_toBottomOf="@id/layoutTags" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>